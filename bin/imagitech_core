            2) /opt/imagitech/bin/imagitech service restart dropbear; pause ;;
            3) /opt/imagitech/bin/imagitech service restart imagitech-ws; pause ;;
            4) /opt/imagitech/bin/imagitech service restart haproxy; pause ;;
            5) /opt/imagitech/bin/imagitech service restart imagitech-xray; pause ;;
            6) /opt/imagitech/bin/imagitech service restart imagitech-dnstt; pause ;;
