        echo -e "  ${CYAN}Xray/V2Ray        :${NC} 80, 8080, 443"
        echo -e "  ${CYAN}SlowDNS (DNSTT)   :${NC} 53, 5300"
        echo -e "  ${CYAN}Nginx Decoy       :${NC} 8081"
        echo -e "  ${CYAN}UDP Custom        :${NC} 1-65535"
        echo -e "  ${CYAN}SOCKS5 Proxy      :${NC} 1080"
        draw_line
