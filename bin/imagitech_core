    echo -e "SSH WS      : 80, 8080, 8880"
    echo -e "SSH WSS     : 443, 8443"
    echo -e "DNSTT       : 53, 5300"
    echo -e "SOCKS5      : ${PORT_SOCKS:-1080}"
    echo -e "UDP Custom  : 1-65535"
    echo -e "========================================"
    echo -e "SSH-80        : ${PRIMARY_DOMAIN}:${PORT_WS_HTTP:-80}@${USERNAME}:${PASSWORD}"
