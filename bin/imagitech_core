        echo -e "  ${CYAN}[05]${NC} Restart Xray Core"
        echo -e "  ${CYAN}[06]${NC} Restart DNSTT"
        echo -e ""
        echo -e "  ${RED}[00]${NC} Return to Main Menu"
        draw_line
        read -p " Select Option : " opt

        case $opt in
