#!/bin/bash
# File: /opt/janabitech/bin/janabitech
# Purpose: The internal CLI API router.

source /opt/janabitech/core/janabitech.conf 2>/dev/null
source /opt/janabitech/lib/users.sh
source /opt/janabitech/lib/system.sh
source /opt/janabitech/lib/services.sh
# FIX: installer_utils.sh MUST be sourced here too. It defines
#      safe_deploy_systemd() and ensure_package(), which xray_install()
#      depends on. Without this, 'janabitech xray install' fails with
#      "safe_deploy_systemd: command not found" because the CLI router
#      never loaded installer_utils.sh (only 05-deploy-xray.sh did).
source /opt/janabitech/lib/installer_utils.sh
source /opt/janabitech/lib/xray.sh

COMMAND="$1"
SUBCOMMAND="$2"
TARGET="$3"
ARG4="$4"
ARG5="$5"
ARG6="$6"
ARG7="$7"

show_help() {
    echo -e "\033[0;36mJANABITECH CLI API\033[0m"
    echo "Usage: janabitech <resource> <action> [args]"
    echo ""
    echo "SSH Commands:"
    echo "  user add <user> <pass> <days> <max_logins> <bw_limit>  - Create a new VPN account"
    echo "  user trial <user> <pass> <hrs> <max_logins> <bw_limit> - Create a trial account"
    echo "  user renew <user> <days>       - Add/deduct days from account"
    echo "  user del <user>                - Delete a VPN account"
    echo ""
    echo "Xray Commands (vmess / vless / trojan):"
    echo "  xray install                          - Install/refresh Xray-core + systemd service"
    echo "  xray add <user> <proto> <val> <unit>  - Create xray account"
    echo "      proto: vmess|vless|trojan"
    echo "      unit : minutes|hours|days"
    echo "  xray trial <user> <proto> <minutes>   - Create trial xray account (default 30 min)"
    echo "  xray renew <user> <val> <unit>        - Renew (positive) or shorten (negative)"
    echo "  xray del <user>                       - Delete xray account"
    echo "  xray list                             - List all xray accounts"
    echo "  xray details <user>                   - Print vmess://, vless://, trojan:// links"
    echo "  xray restart                          - Regenerate config & restart service"
    echo "  xray status                           - Show service info & port layout"
    echo "  xray purge-expired                    - Mark expired users & reload config"
    echo "  xray uninstall                        - Remove Xray-core completely"
    echo ""
    echo "Service Commands:"
    echo "  service restart <name>         - Restart a managed service"
    echo "  config host <domain>           - Update primary domain"
    echo "  config ns <domain>             - Update NS domain"
    echo "  cert renew                     - Force Let's Encrypt renewal"
    echo "  cert status                    - View Let's Encrypt status"
    echo "  dnstt renew                    - Generate new SlowDNS keys"
    echo "  sys autoreboot <hours>         - Set auto-reboot schedule"
    echo "  sys banner                     - Change SSH banner"
    echo "  sys backup                     - Backup database, domains & keys"
    echo "  sys restore <file_path>        - Restore from an archive"
    echo "  sys update                     - Update script from GitHub"
    echo "  sys uninstall                  - Remove Janabitech completely"
}

case "$COMMAND" in
    user)
        case "$SUBCOMMAND" in
            add)   create_vpn_user "$TARGET" "$ARG4" "$ARG5" "$ARG6" "$ARG7" ;;
            trial) create_trial_user "$TARGET" "$ARG4" "$ARG5" "$ARG6" "$ARG7" ;;
            renew) renew_user "$TARGET" "$ARG4" ;;
            del)   delete_vpn_user "$TARGET" ;;
            *)     show_help ;;
        esac
        ;;
    xray)
        case "$SUBCOMMAND" in
            install)        xray_install ;;
            add)            xray_create_user   "$TARGET" "$ARG4" "$ARG5" "$ARG6" ;;
            trial)          xray_create_trial  "$TARGET" "$ARG4" "$ARG5" ;;
            renew)          xray_renew_user    "$TARGET" "$ARG4" "$ARG5" ;;
            del)            xray_delete_user   "$TARGET" ;;
            list)           xray_list_users ;;
            details)        xray_links_for_user "$TARGET" ;;
            restart)        xray_restart ;;
            status)         xray_status ;;
            purge-expired)  xray_purge_expired ;;
            uninstall)      xray_uninstall ;;
            *)              show_help ;;
        esac
        ;;
    service)
        case "$SUBCOMMAND" in
            restart) restart_service "$TARGET" ;;
            *)       show_help ;;
        esac
        ;;
    config)
        case "$SUBCOMMAND" in
            host) change_host_domain "$TARGET" ;;
            ns)   change_ns_domain "$TARGET" ;;
            *)    show_help ;;
        esac
        ;;
    cert)
        case "$SUBCOMMAND" in
            renew)  renew_ssl_cert "$TARGET" ;;
            status) /root/.acme.sh/acme.sh --list ;;
            *)      show_help ;;
        esac
        ;;
    dnstt)
        case "$SUBCOMMAND" in
            renew) generate_dnstt_key ;;
            *)     show_help ;;
        esac
        ;;
    sys)
        case "$SUBCOMMAND" in
            autoreboot) set_auto_reboot "$TARGET" ;;
            banner)     change_banner ;;
            backup)     create_backup ;;
            restore)    restore_backup "$TARGET" ;;
            update)     update_script ;;
            uninstall)  uninstall_script ;;
            online)
                if [ -f "/opt/janabitech/core/online_users.txt" ]; then
                    cat "/opt/janabitech/core/online_users.txt"
                else
                    echo "Daemon is starting up..."
                fi
                ;;
            fail2ban)   install_fail2ban ;;
            *)          show_help ;;
        esac
        ;;
    *)
        show_help
        ;;
esac

